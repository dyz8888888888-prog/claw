# ===== 可转债日内联动监控系统 - 环境变量 =====
# 复制为 .env 并填入实际值

# 同花顺/扶摇 API Key (共识追踪器全市场数据)
FUYAO_API_KEY=sk-fuyao-xxx

# 仪表盘访问令牌 (强烈建议设置，否则任何人均可访问)
DASHBOARD_TOKEN=your-secret-token-here

# 飞书 Webhook (可选, 通知推送)
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 仪表盘监听地址 (默认 127.0.0.1 仅本机)
# 如需局域网/公网访问: DASHBOARD_HOST=0.0.0.0，并必须设置 DASHBOARD_TOKEN
# DASHBOARD_HOST=0.0.0.0

# 概念映射文件路径 (可选，默认 ../可转债日报/cb_concept_map.json)
# CONCEPT_MAP_PATH=C:/path/to/cb_concept_map.json
